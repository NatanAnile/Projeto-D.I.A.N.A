# =========================
# Projeto Diana V5 — exemplo de configuração
# =========================

# LLM
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9

# STT
PUSH_TO_TALK_KEY=right ctrl
PTT_START_TIMEOUT_SECONDS=3.0
PTT_MAX_RECORD_SECONDS=12.0
PTT_SILENCE_ABORT_SECONDS=2.0
PTT_RELEASE_LOCKOUT_ENABLED=true
LOAD_STT=true
STT_ENGINE=parakeet
DIANA_MODELS_DIR=
PARAKEET_MODEL_PATH=
PARAKEET_AUTO_DOWNLOAD=true

# TTS
TTS_ENABLED=false
TTS_PROVIDER=xtts
TTS_FALLBACK=xtts
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Resumo de sessão
SESSION_SUMMARIZER_ENABLED=false
SESSION_SUMMARIZER_TRIGGER_TURNS=10
SESSION_SUMMARIZER_BATCH_TURNS=5
SESSION_SUMMARIZER_MAX_TOKENS=700
